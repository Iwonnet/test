model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: pl-PL
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["FactSales","DimStore","DimChannel","DimProduct","MyMeasures","Trend"]

annotation PBI_ProTooling = ["DevMode"]

ref table FactSales
ref table DimStore
ref table DimChannel
ref table DimProduct
ref table Date
ref table MyMeasures
ref table Trend

ref cultureInfo en-US

