	partition Date = calculated
		mode: import
		source = ```
				
				 var _calendar = CALENDARAUTO()
				 RETURN
				 ADDCOLUMNS(_calendar,
				 "Year",YEAR([Date]),
				 "Month", FORMAT([Date],"mmmm"),
				 "MonthShort", FORMAT([Date],"mmm"),
				 "MonthNumber", MONTH([Date]),
				 "Quarter","QTR " & FORMAT([Date],"Q"),
				 "QuarterNumber", FORMAT([Date],"Q"),
				 "MonthYear", FORMAT([Date],"mmm yyyy")
				 --"MonthYearNumber", FORMAT([Date],"mmm yy")
				 )
				```

	annotation PBI_Id = d44f79bc9f8a40deb3c4cf995b768167

